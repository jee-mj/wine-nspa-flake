+static void remove_caps_suffix(char *name, const char *suffix)
+{
+    size_t name_len = strlen(name), suffix_len = strlen(suffix);
+
+    if (name_len >= suffix_len && !strcmp(name + name_len - suffix_len, suffix))
+        name[name_len - suffix_len] = 0;
+}
+
+static void make_caps_name(WCHAR *dst, size_t max, const char *name)
+{
+    static const char midi_bridge_prefix[] = "Midi-Bridge:";
+    char buf[128];
+    const char *p = name;
+    const char *colon;
+    char *end;
+
+    /*
+     * WinMM exposes only MAXPNAMELEN WCHARs, so WineJACK used to keep just
+     * the substring after the last JACK ':' separator.  PipeWire's ALSA MIDI
+     * bridge names Push 3 ports like:
+     *
+     *   Midi-Bridge:Ableton Push 3: Live Port (capture)
+     *
+     * Keeping only the final component exposes " Live Port (capture)" to
+     * Windows apps.  Ableton's Push3.exe enumerates MIDI devices by WinMM
+     * caps name and matches with std::regex_match(name + " " + index, re).
+     * The embedded regex expects the device-name component only:
+     *
+     *   Ableton Push 3 (\\d*|Live Port|MIDI [0-9]+|[0-9][0-9]:0)
+     *
+     * With the old stripped name the helper rejects every device before
+     * midiInOpen().  With a prefix-preserving name like "Ableton Push 3
+     * Live Port" the regex still fails because the trailing " Live Port"
+     * leaves unconsumed characters after the index-concatenated match.
+     *
+     * Preserve only the JACK client (device) name — the segment between
+     * the "Midi-Bridge:" prefix and the first colon after it.  Drop the
+     * direction suffix added by the bridge.
+     */
+    if (!strncmp(p, midi_bridge_prefix, strlen(midi_bridge_prefix)))
+        p += strlen(midi_bridge_prefix);
+
+    colon = strchr(p, ':');
+    if (colon)
+    {
+        size_t n = colon - p;
+        if (n >= sizeof(buf)) n = sizeof(buf) - 1;
+        memcpy(buf, p, n);
+        buf[n] = 0;
+    }
+    else
+    {
+        size_t n = strlen(p);
+        if (n >= sizeof(buf)) n = sizeof(buf) - 1;
+        memcpy(buf, p, n);
+        buf[n] = 0;
+    }
+
+    remove_caps_suffix(buf, " (capture)");
+    remove_caps_suffix(buf, " (playback)");
+
+    p = buf;
+    while (*p == ' ') p++;
+    end = buf + strlen(buf);
+    while (end > p && end[-1] == ' ') *--end = 0;
+
+    copy_caps_name(dst, max, p);
+}

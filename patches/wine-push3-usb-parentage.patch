+                               (wcslen(link_path) + 1) * sizeof(WCHAR) );
+
+        /* Register GUID_DEVINTERFACE_USB_HUB for hub-class devices. */
+        if (!(device->interface) && device->class == 0x09)
+        {
+            swprintf( iface_key, ARRAY_SIZE(iface_key),
+                      L"\\Registry\\Machine\\System\\CurrentControlSet\\Control\\"
+                      L"DeviceClasses\\{F18A0E88-C30C-11D0-8815-00A0C906BED8}\\\\"
+                      L"?\\USB#VID_%04X&PID_%04X#%u&%u&%u&%u#{F18A0E88-C30C-11D0-8815-00A0C906BED8}",
+                      device->vendor, device->product, device->usbver,
+                      device->revision, device->busnum, device->portnum );
+            RtlWriteRegistryValue( RTL_REGISTRY_ABSOLUTE, iface_key,
+                                   L"DeviceInstance", REG_SZ, instance_id,
+                                   (wcslen(instance_id) + 1) * sizeof(WCHAR) );
+            wcscat( iface_key, L"\\#" );
+            RtlWriteRegistryValue( RTL_REGISTRY_ABSOLUTE, iface_key,
+                                   L"SymbolicLink", REG_SZ, link_path,
+                                   (wcslen(link_path) + 1) * sizeof(WCHAR) );
+        }
+    }
